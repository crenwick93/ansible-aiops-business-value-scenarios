# =============================================================================
# AIOps Demo — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# Every variable used by Terraform, Ansible, the CMDB scripts, and the
# Makefile is sourced from this single file.
#
# IMPORTANT: Do NOT put inline comments on the same line as a value.
# Make's include directive treats everything after = as the value.
# =============================================================================

# --- AWS ---------------------------------------------------------------------
# IAM credentials with permissions to create VPC, EC2, SGs, and IAM roles.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# --- SSH key for EC2 access --------------------------------------------------
# Name of an existing AWS EC2 key pair (appears in the EC2 console).
SSH_KEY_NAME=
# Local path to the matching private key file.
SSH_PRIVATE_KEY_PATH=

# --- ServiceNow PDI ---------------------------------------------------------
# A Personal Developer Instance from developer.servicenow.com.
# e.g. https://devXXXXXX.service-now.com
SERVICENOW_INSTANCE_URL=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=
# Name used as the demo caller in ServiceNow (created during CMDB seeding) - Can be your own name 
SERVICENOW_CALLER_NAME="Chris Renwick"

# --- AAP (Ansible Automation Platform) ----------------------------------------
# Gateway URL for your AAP 2.5+ instance (e.g. https://aap.sandbox2797.opentlc.com)
AAP_HOSTNAME=
# OAuth2 token for API access (generate in AAP > Users > Tokens)
# Also used as the ALIA (Ansible Lightspeed Intelligent Assist) bearer token —
# ALIA authenticates through the AAP gateway, no separate token needed.
AAP_TOKEN=
# Set to "false" for self-signed certs on the AAP instance
AAP_VALIDATE_CERTS=false
# Shared password for per-org admin users (app_admin, db_admin, middleware_admin,
# storage_admin, sre_admin). Used during demo to log in as different teams and
# browse their automation catalogs.
AAP_ORG_ADMIN_PASSWORD=example_pass
# Git repo URL used by AAP projects (defaults to this repo if left blank)
GIT_REPO_URL=https://github.com/crenwick93/ansible-aiops-business-value-scenarios.git
# Decision Environment image for EDA (pre-built with ServiceNow collection)
DE_IMAGE=quay.io/crenwick93/snow-de:latest
# Path to the SSH private key used for the Machine credential in AAP
MONITORING_SSH_KEY_PATH=

# --- DNS (Route53) -----------------------------------------------------------
# Base domain for the demo. Each service gets a subdomain:
#   payment-svc.<domain>, app-svc.<domain>, dashboard.<domain>,
#   kafka.<domain>, postgres.<domain>
# Must be a domain with an existing Route53 hosted zone in your account.
# Leave blank to skip DNS and use raw IP addresses instead.
DEMO_DOMAIN=sandbox3331.opentlc.com

# --- Demo settings -----------------------------------------------------------
# AWS tag used for resource grouping and cleanup
DEMO_PROJECT_TAG=aiops-demo

# --- Storage S3 (generated by Terraform) ------------------------------------
# Read-only credentials for the passport-document-uploads S3 bucket.
# These are created by Terraform (see: terraform output storage_diag_credentials)
# and have access to ONLY this one bucket — nothing else.
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_BUCKET_NAME=
